beccc4b869e9fa8e96aa5279c0af-3456x5184.jpg)\\\"},\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute inset-0 bg-black\\\",\\\"style\\\":{\\\"opacity\\\":0.4}}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-4xl mx-auto text-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 font-serif drop-shadow-xl\\\",\\\"children\\\":\\\"About Wookporium\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xl md:text-2xl text-white/90 mb-8 drop-shadow-md font-light\\\",\\\"children\\\":\\\"Handcrafted festival fashion made with love\\\"}]]}]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"py-16 md:py-24 bg-warm-white\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container mx-auto px-4\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-6xl mx-auto\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid md:grid-cols-2 gap-12 items-center\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"order-2 md:order-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold text-accent-dark mb-6 font-serif\\\",\\\"children\\\":\\\"Our Story\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose prose-lg max-w-none text-lg text-cream leading-relaxed\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"04a2775a3a53\\\",{\\\"className\\\":\\\"mb-4 leading-relaxed text-base md:text-lg\\\",\\\"children\\\":[\\\"The Wookporium started exactly where you’d expect: in the middle of the crowd, surrounded by bass, incredible energy, and the best-dressed people on the planet.\\\",[\\\"$\\\",\\\"br\\\",\\\"node-1\\\",{}],\\\"\\\",[\\\"$\\\",\\\"br\\\",\\\"node-3\\\",{}],\\\"Driven by a love for festival culture and a deep obsession with creating things by hand, Marina started making pieces that capture that exact high-alpine, main-stage magic. Every single item, from our hand-crocheted clothing to our natural jewelry, is dreamed up and crafted to bring a little extra joy, confidence, and color to your next show.\\\",[\\\"$\\\",\\\"br\\\",\\\"node-5\\\",{}],\\\"\\\",[\\\"$\\\",\\\"br\\\",\\\"node-7\\\",{}],\\\"We believe in good vibes, unforgettable sets, keeping your festival wardrobe premium, and, honestly? Keeping Marina’s horses fed. Because every piece you take home doesn't just get you hooked up with a gorgeous new look, it funds a lifelong equestrian passion, too.\\\",[\\\"$\\\",\\\"br\\\",\\\"node-9\\\",{}],\\\"\\\",[\\\"$\\\",\\\"br\\\",\\\"node-11\\\",{}],\\\"Made by hand. Worn in the crowd. Built for the beautiful people who make the scene what it is.\\\"]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-8 \\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"font-accent text-3xl md:text-4xl text-terracotta transform -rotate-2 origin-bottom-left mb-2\\\",\\\"children\\\":\\\"Marina\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-secondary text-sm uppercase tracking-widest font-semibold ml-1\\\",\\\"children\\\":\\\"Founder \\u0026 Curator\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"order-1 md:order-2\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative aspect-square rounded-2xl overflow-hidden shadow-xl\\\",\\\"children\\\":[\\\"$\\\",\\\"$L11\\\",null,{\\\"src\\\":\\\"https://cdn.sanity.io/images/7iiji3rf/production/1dce159e6531a2ca37072839f65d85a72f9b5258-2486x2590.jpg\\\",\\\"alt\\\":\\\"Our Story\\\",\\\"fill\\\":true,\\\"className\\\":\\\"object-cover\\\",\\\"sizes\\\":\\\"(max-width: 768px) 100vw, 50vw\\\"}]}]}]]}]}]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"py-16 md:py-24 bg-primary/5\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container mx-auto px-4\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-6xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold text-accent-dark text-center mb-12 font-serif\\\",\\\"children\\\":\\\"What We Believe\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",\\\"0\\\",{\\\"className\\\":\\\"bg-white/60 backdrop-blur-md shadow-lg border border-white/40 rounded-xl p-8 hover:transform hover:scale-105 transition-all duration-300\\\",\\\"children\\\":[null,[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-semibold text-accent-dark mb-3\\\",\\\"children\\\":\\\"Made for the Music\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-cream leading-relaxed\\\",\\\"children\\\":\\\"We believe festival fashion should be as unforgettable as the sets you catch. Every piece is built to stand out, dance comfortably, and handle the energy of the crowd.\\\"}]]}],[\\\"$\\\",\\\"div\\\",\\\"1\\\",{\\\"className\\\":\\\"bg-white/60 backdrop-blur-md shadow-lg border border-white/40 rounded-xl p-8 hover:transform hover:scale-105 transition-all duration-300\\\",\\\"children\\\":[null,[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-semibold text-accent-dark mb-3\\\",\\\"children\\\":\\\"Slow, Intentional Fashion\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-cream leading-relaxed\\\",\\\"children\\\":\\\"No mass factories here. We reject fast fashion by keeping production entirely in-house. When you wear our apparel, you're wearing an authentic, premium piece made step-by-step by real hands.\\\"}]]}],[\\\"$\\\",\\\"div\\\",\\\"2\\\",{\\\"className\\\":\\\"bg-white/60 backdrop-blur-md shadow-lg border border-white/40 rounded-xl p-8 hover:transform hover:scale-105 transition-all duration-300\\\",\\\"children\\\":[null,[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-xl font-semibold text-accent-dark mb-3\\\",\\\"children\\\":\\\"Spreading Real Joy\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-cream leading-relaxed\\\",\\\"children\\\":\\\"The absolute best part of this side business is getting people hooked up with cute apparel they genuinely love. We create to bring extra color, confidence, and smiles to the beautiful people in our community.\\\"}]]}]]}]]}]}]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"py-16 md:py-24 bg-warm-white\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container mx-auto px-4\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-6xl mx-auto\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold text-accent-dark text-center mb-12 font-serif\\\",\\\"children\\\":\\\"How We Create\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"max-w-3xl mx-auto mb-12\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-lg text-cream leading-relaxed text-center\\\",\\\"children\\\":\\\"Every design at The Wookporium begins with inspiration pulled directly from the festival grounds—the vibrant lights, the movement of the crowd, and the natural textures of high-alpine environments.\\\\n\\\\nMarina obsessively selects ultra-soft, premium yarns for her apparel and sources high-quality crystals and earth-grown materials for her handmade jewelry. From the very first stitch of a bucket hat to the intricate wrapping of a pendant, everything is crafted by hand during focused hours at her workspace.\\\\n\\\\nWhen she isn't buried in yarn or designing new festival fits, she’s out at the stables tending to her horses. Your support doesn't just fund independent, handmade art—it directly fuels an authentic passion for the music community and a lifelong equestrian dream. Every piece truly tells a story.\\\"}]}],[\\\"$\\\",\\\"div\\\",null,{