px] flex items-center gap-2\" aria-label=\"Shopping cart with 0 items\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z\"></path></svg><span class=\"hidden sm:inline\">Cart</span></button></div><div class=\"flex items-center gap-2 lg:hidden\"><button class=\"relative p-2 text-primary hover:bg-cream rounded-lg transition-colors min-w-[44px] min-h-[44px]\" aria-label=\"Shopping cart with 0 items\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z\"></path></svg></button><button class=\"p-2 text-dark-brown hover:bg-cream rounded-lg transition-colors min-w-[44px] min-h-[44px]\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></nav></header><main class=\"flex-grow\"><main class=\"min-h-screen\"><div class=\"relative w-full min-h-[80vh] parallax-bg flex items-center justify-center overflow-hidden\" style=\"background-image:url(https://cdn.sanity.io/images/7iiji3rf/production/19b65cb2d91d7abc750bc59085c304edf45e852f-4729x3076.jpg)\"><div class=\"absolute inset-0 bg-black\" style=\"opacity:0.7\"></div><div class=\"relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\"><div class=\"relative z-10 text-center max-w-4xl mx-auto space-y-8 py-20\"><div class=\"\" style=\"opacity:0;transform:translateY(30px)\"><h1 class=\"text-6xl md:text-8xl font-serif text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent drop-shadow-[0_0_15px_rgba(0,240,255,0.4)]\">Wookporium</h1></div><div class=\"\" style=\"opacity:0;transform:translateY(30px)\"><p class=\"text-xl md:text-3xl text-warm-white drop-shadow-md max-w-3xl mx-auto leading-relaxed font-light\">Handcrafted festival apparel and natural jewelry for your journey, wherever it takes you</p></div><div class=\"\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"flex flex-col sm:flex-row gap-6 justify-center pt-8\"><a class=\"btn-primary text-lg\" href=\"/products\">Shop Collection 🌿</a><a class=\"glass-dark px-10 py-4 rounded-full font-bold text-warm-white hover:text-primary transition-all duration-200 text-lg shadow-[0_0_15px_rgba(0,0,0,0.5)] hover:shadow-[0_0_20px_rgba(0,240,255,0.3)]\" href=\"/about\">Our Story</a></div></div></div></div></div><section class=\"section-container max-w-4xl mx-auto\"><div class=\"prose prose-lg max-w-none text-center\"><h2 class=\"text-3xl md:text-4xl font-bold mb-5 font-serif leading-tight\">Made for the Music. Built for the Vibes.</h2><p class=\"mb-4 leading-relaxed text-base md:text-lg\">At <strong class=\"font-bold \">The Wookporium</strong>, we don’t do mass production. We do authentic, high-quality, hand-crafted apparel that stands out in the crowd. From intricate crochet wear to raw, natural statement jewelry, our pieces are born from a love of festival culture and the beautiful community that makes it what it is.</p><p class=\"mb-4 leading-relaxed text-base md:text-lg\"><em class=\"italic\">Step into the collection below and get hooked up for the next main stage.</em></p></div></section><div class=\"relative w-full min-h-screen parallax-bg flex items-center justify-center overflow-hidden\" style=\"background-image:url(/images/backgrounds/concert-blue-atmosphere.png)\"><div cla