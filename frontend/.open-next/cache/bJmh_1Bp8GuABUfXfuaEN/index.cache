&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fcdn.sanity.io%2Fimages%2F7iiji3rf%2Fproduction%2Fb9d7cc04ed9541a6ac31efe53fa96a641e7a6ceb-4000x6000.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fcdn.sanity.io%2Fimages%2F7iiji3rf%2Fproduction%2Fb9d7cc04ed9541a6ac31efe53fa96a641e7a6ceb-4000x6000.jpg&amp;w=1920&amp;q=75 1920w\" src=\"/_next/image?url=https%3A%2F%2Fcdn.sanity.io%2Fimages%2F7iiji3rf%2Fproduction%2Fb9d7cc04ed9541a6ac31efe53fa96a641e7a6ceb-4000x6000.jpg&amp;w=1920&amp;q=75\"/><div class=\"absolute top-4 right-4 bg-accent/90 backdrop-blur text-deep-bg px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider shadow-[0_0_10px_rgba(176,38,255,0.8)]\">One of a Kind</div></div><div class=\"p-6 text-left border-t border-white/10\"><h3 class=\"text-2xl font-serif font-bold text-warm-white mb-2 group-hover:text-primary transition-colors drop-shadow-md\">Crochet Top</h3><div class=\"flex items-center justify-between mt-4\"><span class=\"text-xl font-bold text-primary drop-shadow-[0_0_8px_rgba(0,240,255,0.5)]\">$<!-- -->140</span><span class=\"text-xs font-bold text-secondary uppercase tracking-widest border border-secondary/50 px-2 py-1 rounded drop-shadow-[0_0_5px_rgba(255,0,170,0.5)]\">tops</span></div></div></a></div></div><div class=\"text-center mt-16\"><a class=\"btn-outline inline-block text-lg glass-dark\" href=\"/products\">View All Products →</a></div></div></div></div><section class=\"bg-surface-dark py-20 px-4 relative z-20 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.8)] border-t border-b border-primary/20\"><div class=\"\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"max-w-4xl mx-auto text-center\"><h2 class=\"text-5xl md:text-6xl font-header text-primary drop-shadow-[0_0_10px_rgba(0,240,255,0.4)] mb-6\">What Festival Fam Say</h2><p class=\"text-xl text-secondary drop-shadow-[0_0_8px_rgba(255,0,170,0.4)] max-w-2xl mx-auto font-bold tracking-wide\">Real reviews from real people</p></div></div></section><section class=\"relative py-24 px-4 parallax-bg\" style=\"background-image:url(/images/backgrounds/festival-crowd-lights.png);background-attachment:fixed;background-position:center;background-size:cover\"><div class=\"absolute inset-0 bg-primary/10 backdrop-blur-sm\"></div><div class=\"relative z-10 max-w-7xl mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\"><div class=\"\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"bg-surface-dark/60 backdrop-blur-md rounded-2xl p-8 shadow-[0_0_20px_rgba(0,0,0,0.6)] border border-white/10 hover:border-accent/50 hover:shadow-[0_0_20px_rgba(176,38,255,0.3)] hover:transform hover:-translate-y-2 transition-all duration-300 h-full flex flex-col\"><div class=\"flex items-center gap-1 mb-6\"><span class=\"text-accent text-lg drop-shadow-[0_0_5px_rgba(176,38,255,0.8)]\">⭐</span><span class=\"text-accent text-lg drop-shadow-[0_0_5px_rgba(176,38,255,0.8)]\">⭐</span><span class=\"text-accent text-lg drop-shadow-[0_0_5px_rgba(176,38,255,0.8)]\">⭐</span><span class=\"text-accent text-lg drop-shadow-[0_0_5px_rgba(176,38,255,0.8)]\">⭐</span><span class=\"text-accent text-lg drop-shadow-[0_0_5px_rgba(176,38,255,0.8)]\">⭐</span></div><p class=\"text-warm-white mb-6 leading-relaxed italic text-lg flex-grow\">&quot;<!-- -->I bought one of Marina&#x27;s hand-crocheted halter tops at a festival last summer and I am absolutely obsessed. The stitching is so sturdy, it survived an entire weekend of dancing in the dust and still looks brand new. I got so many compliments on the colors! Definitely worth every penny for premium, real handmade stuff.<!-- -->&quot;</p><div class=\"flex items-center gap-4 mt-auto border-t border-white/10 pt-4\"><div><p class=\"font-bold text-warm-white text-lg drop-shadow-sm\">Chloe M.</p><p class=\"text-sm text-primary font-bold\">E-Forest 2026!!!</p></div></div></div></div></div></div></section></main></main><footer class=\"relative mt-20\"><div class=\"absolute inset-0 bg-gradient-to-t 