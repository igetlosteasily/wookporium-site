t src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen bg-deep-bg text-warm-white antialiased selection:bg-secondary selection:text-white\"><header class=\"sticky top-0 z-50 glass-light glass-shadow transition-all duration-300 \"><nav class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\" aria-label=\"Main navigation\"><div class=\"flex items-center justify-between h-16\"><a class=\"flex items-center space-x-2 focus-visible-ring rounded-lg\" href=\"/\"><span class=\"text-2xl sm:text-3xl font-header font-bold text-primary\">Wookporium</span></a><div class=\"hidden lg:flex lg:items-center lg:space-x-8\"><a class=\"\n                  text-lg font-semibold transition-colors duration-200\n                  focus-visible-ring rounded-lg px-3 py-2\n                  text-dark-brown hover:text-primary\n                \" href=\"/\">Home</a><a class=\"\n                  text-lg font-semibold transition-colors duration-200\n                  focus-visible-ring rounded-lg px-3 py-2\n                  text-dark-brown hover:text-primary\n                \" href=\"/collections\">Collections</a><a class=\"\n                  text-lg font-semibold transition-colors duration-200\n                  focus-visible-ring rounded-lg px-3 py-2\n                  text-dark-brown hover:text-primary\n                \" href=\"/about\">About</a><div class=\"relative\"><button class=\"\n                  text-lg font-semibold transition-colors duration-200\n                  focus-visible-ring rounded-lg px-3 py-2 flex items-center gap-1\n                  text-dark-brown hover:text-primary\n                \" aria-expanded=\"false\" aria-haspopup=\"true\">Shop<svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></button></div><button class=\"btn-primary relative min-w-[44px] min-h-[44px] flex items-center gap-2\" aria-label=\"Shopping cart with 0 items\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z\"></path></svg><span class=\"hidden sm:inline\">Cart</span></button></div><div class=\"flex items-center gap-2 lg:hidden\"><button class=\"relative p-2 text-primary hover:bg-cream rounded-lg transition-colors min-w-[44px] min-h-[44px]\" aria-label=\"Shopping cart with 0 items\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z\"></path></svg></button><button class=\"p-2 text-dark-brown hover:bg-cream rounded-lg transition-colors min-w-[44px] min-h-[44px]\" aria-label=\"Open menu\" aria-expanded=\"false\" aria-controls=\"mobile-menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></nav></header><main class=\"flex-grow\"><main class=\"min-h-screen\"><div class=\"relative w-full min-h-[40vh] md:min-h-[50vh] parallax-bg flex items-center justify-center overflow-hidden\" style=\"background-image:url(/images/backgrounds/forest-stage.jpg)\"><div class=\"absolute inset-0 bg-black\" style=\"opacity:0.5\"></div><div class=\"relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center\"><div class=\"max-w-4xl mx-auto text-center\"><h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 font-serif drop-shadow-xl\">Let&#x27;s Connect</h1><p class=\"text-xl md:text-2xl text-white/90 mb-8 drop-shadow-md font-light\">Commissions, collaborations, or just saying hello</p></div></div></div><section class=\"py-16 md:py-24 bg-warm-white relative\"><div class=\"absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none\"><div class=\"absolute top-[10%] left-[-10%] w-[40%] h-[40%] bg-terracotta/5 rounded-full blur-[100px]\"></div><div class=\"absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] bg-sage/5 rounded-full blur-[100px]\"></div></div><div class=\"container mx-auto px-4 relative z-10\"><div class=\"max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20\"><div class=\"space-y-8\"><div><h2 class=\"text-3xl font-bold text-brown-warm mb-4 font-serif\">Get in Touch</h2><p class=\"text-lg text-gray-700 leading-relaxed\">Have a vision for a custom piece? Need help with an order? We love hearing from the festival family. Drop us a line and we&#x27;ll get back to you as soon as we&#x27;re out of the woods.</p></div><div class=\"glass-light glass-shadow rounded-2xl p-8 space-y-6\"><div><h3 class=\"font-bold text-terracotta mb-2 uppercase tracking-wide text-sm\">Email Us</h3><a href=\"mailto:hello@wookporium.com\" class=\"text-xl text-dark-brown hover:text-primary transition-colors font-medium\">hello@wookporium.com</a></div><div><h3 class=\"font-bold text-terracotta mb-2 uppercase tracking-wide text-sm\">Socials</h3><div class=\"flex gap-4\"></div></div></div><div class=\"bg-primary/5 border border-primary/10 rounded-2xl p-8\"><h3 class=\"font-bold text-primary mb-2\">Commission Status: <span class=\"text-green-600\">OPEN</span></h3><p class=\"text-gray-700 text-sm\">We are currently accepting custom orders for the upcoming festival season. Turnaround time is typically 3-4 weeks.</p></div></div><div class=\"glass-white glass-shadow-xl rounded-2xl p-8 md:p-10 border border-white/50\"><h2 class=\"text-2xl font-bold text-brown-warm mb-6 font-serif\">Send a Message</h2><form class=\"space-y-6\"><div class=\"grid md:grid-cols-2 gap-6\"><div class=\"space-y-2\"><label for=\"name\" class=\"text-sm font-semibold text-gray-700\">Name</label><input type=\"text\" id=\"name\" class=\"w-full px-4 py-3 rounded-lg bg-white/50 border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-gray-400\" placeholder=\"Your name\"/></div><div class=\"space-y-2\"><label for=\"email\" class=\"text-sm font-semibold text-gray-700\">Email</label><input type=\"email\" id=\"email\" class=\"w-full px-4 py-3 rounded-lg bg-white/50 border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-gray-400\" placeholder=\"you@email.com\"/></div></div><div class=\"space-y-2\"><label for=\"subject\" class=\"text-sm font-semibold text-gray-700\">Subject</label><select id=\"subject\" class=\"w-full px-4 py-3 rounded-lg bg-white/50 border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-gray-700\"><option value=\"general\">General Inquiry</option><option value=\"commission\">Custom Commission Request</option><option value=\"order\">Order Help</option><option value=\"collaboration\">Collaboration</option></select></div><div class=\"space-y-2\"><label for=\"message\" class=\"text-sm font-semibold text-gray-700\">Message</label><textarea id=\"message\" rows=\"6\" class=\"w-full px-4 py-3 rounded-lg bg-white/50 border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all placeholder:text-gray-400 resize-none\" placeholder=\"Tell us what&#x27;s on your mind... (For commissions, please include size, desired colors, and vibe)\"></textarea></div><button type=\"button\" class=\"w-full btn-primary py-4 text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300\">Send Message 🌿</button></form></div></div></div></section></main></main><footer class=\"relative mt-20\"><div class=\"absolute inset-0 bg-gradient-to-t from-[#2c1810] via-[#3d2e29] to-transparent opacity-90 -z-10\"></div><div class=\"glass-dark glass-shadow-xl border-t border-white/10 backdrop-blur-xl\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"space-y-4\"><h3 class=\"text-2xl font-header font-bold text-primary\">Wookporium</h3><p class=\"text-warm-white/80 text-sm leading-relaxed\">Handcrafted festival apparel and natural jewelry for your journey, whatever that may be!</p><div class=\"flex gap-4 pt-2\"></div></div><div><h4 class=\"text-lg font-semibold mb-4 text-primary\">Shop</h4><ul class=\"space-y-2\"><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products\">All Products</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=tops\">Tops</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=bottoms\">Bottoms</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=outerwear\">Outerwear</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=headwear\">Headwear</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=jewelry\">Jewelry</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=accessories\">Accessories</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/products?category=knick-knacks\">Knick-knacks</a></li></ul></div><div><h4 class=\"text-lg font-semibold mb-4 text-primary\">Info</h4><ul class=\"space-y-2\"><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/about\">About Us</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/contact\">Contact</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/faq\">FAQ</a></li><li><a class=\"text-warm-white/80 hover:text-primary transition-colors text-sm\" href=\"/shipping-returns\">Shipping &amp; Returns</a></li></ul></div><div><h4 class=\"text-lg font-semibold mb-4 text-primary\">Stay Connected</h4><p class=\"text-warm-white/80 text-sm mb-4\">Follow us on social media for new drops, festival updates, and behind-the-scenes!</p></div></div></div><div class=\"border-t border-warm-white/20\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6\"><div class=\"flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-warm-white/60\"><p>© <!-- -->2026<!-- --> Wookporium. All rights reserved. Made with 💚</p><div class=\"flex gap-6\"><a class=\"hover:text-primary transition-colors\" href=\"/privacy\">Privacy Policy</a><a class=\"hover:text-primary transition-colors\" href=\"/terms\">Terms of Service</a></div></div></div></div></div></footer><script src=\"/_next/static/chunks/webpack-82e677544ab9f0cf.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7863,[\\\"173\\\",\\\"static/chunks/173-070ddf095c6be93e.js\\\",\\\"274\\\",\\\"static/chunks/274-f03681e9fcaf2d52.js\\\",\\\"177\\\",\\\"static/chunks/app/layout-4e6b976042042964.js\\\"],\\\"default\\\"]\\n3:I[9909,[\\\"173\\\",\\\"static/chunks/173-070ddf095c6be93e.js\\\",\\\"274\\\",\\\"static/chunks/274-f03681e9fcaf2d52.js\\\",\\\"177\\\",\\\"static/chunks/app/layout-4e6b976042042964.js\\\"],\\\"default\\\"]\\n4:I[5244,[],\\\"\\\"]\\n5:I[3866,[],\\\"\\\"]\\n7:I[670,[\\\"173\\\",\\\"static/chunks/173-070ddf095c6be93e.js\\\",\\\"274\\\",\\\"static/chunks/274-f03681e9fcaf2d52.js\\\",\\\"177\\\",\\\"static/chunks/app/lay